# Configure script from linux from scratch

_realname=binutils
_target=x86_64-linux-gnu

pkgbase=${_target}-${_realname}
pkgname=("${_target_-${_realname}")
pkgver=2.46.0
pkgrel=1
pkgdesc="GNU tools for building linux programs"
arch=('any')
license=('GLP')
url='https://www.gnu.org/software/binutils/binutils.html'
msys2_references=(
  "cpe: cpe:/a:gnu:binutuls"
)
depends=('zstd'
         'zlib')
makedepends=('autotools' 'bison' 'gawk' 'gcc' texinfo'
             'gettext-devel' 'libzstd-devel' 'zlib-devel')
source=("https://ftp.gnu.org/gnu/${_realname}/${_realname}-${pkgver}.tar.xz")
sha256sums=('SKIP')

validpgpkeys=('EAF1C276A747E9ED86210CBAC3126D3B4AE55E93'
              '3A24BC1E8FB409FA9F14371813FCEF89DD9E3C4F'
              '5EF3A41171BB77E6110ED2D01F3D03348DB1A3E2')

build() {
	mkdir -p "${srcdir}"/build-${MSYSTEM} && cd "${srcdir}"/build-${MSYSTEM}
	
	../${_realname}-${pkgver}/configure \
	   --build=${CHOST} \
	   --host=${CHOST} \
	   --prefix=/usr \
	   --target-${_target} \
	   --libdir=/usr/${_target}/lib \
	   --includedir=/usr/${_target}/include \
	   --enable-ld=default \
	   --enable-plugins \
	   --enable-shared \
	   --diable-werror \
	   --enable-64-bit-bdf \
	   --enable-new-dtags \
	   --with-system-zlib \
	   --enable-default-hash-style=gnu
	make
}

package() {
	cd "${srcdir}"/build-${MSYSTEM}
	
	make DESTDIR=${pkgdir}" install
	
	cd "${pkgdir}/${_target}
	
	for info in as bfd bintuils ctf-spec gprof ld ldint sframe-spec; do
	  mv share/info/${info}.info share/info/${_target}-${info}.info
	done
}